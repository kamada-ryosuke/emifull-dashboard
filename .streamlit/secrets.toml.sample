# Streamlit Cloud の Advanced settings > Secrets に貼り付けるサンプルです。
# 実際の値に置き換えて使ってください。

TURSO_DATABASE_URL = "libsql://your-database.turso.io"
TURSO_AUTH_TOKEN = "your-token"

# AI要約を使う場合だけ設定してください。
# 未設定でもアプリは動き、簡易要約に切り替わります。
OPENAI_API_KEY = "sk-..."

# OCRなど Anthropic 連携を使う場合だけ設定してください。
ANTHROPIC_API_KEY = "sk-ant-..."

# Notion連携を使う場合だけ設定してください。
NOTION_API_TOKEN = "ntn_..."

# メール自動送信を使う場合だけ設定してください。
[smtp]
host = "smtp.gmail.com"
port = 587
username = "your-email@gmail.com"
password = "gmail-app-password"
sender = "your-email@gmail.com"
use_tls = true

# 注意:
# 公開環境では CODEX_AUTO_LOGIN を設定しないでください。
